# Base de données MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=quicklodge_db
MYSQL_USER=root
MYSQL_PASSWORD=

# JWT (en production : clé longue et secrète, min 32 caractères pour HS256)
JWT_SECRET=your-256-bit-secret-key-min-32-chars-for-hs256
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_ISSUER=quicklodge-platform

# Profil Spring actif (dev, prod)
SPRING_PROFILES_ACTIVE=dev
