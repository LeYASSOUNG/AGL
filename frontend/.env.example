## Frontend environment variables
#
# Dev : le proxy envoie /api vers le backend (par défaut http://localhost:8080).
# Si tu vois ECONNREFUSED, démarre l'API : cd backend && mvn spring-boot:run
# (MySQL doit tourner et la base configurée.)
#
# Autre port / autre machine :
# VITE_DEV_PROXY_TARGET=http://localhost:8080
#
# Dev (recommended): leave empty to use Vite proxy "/api" -> backend
# Prod (frontend and backend on different domains):
#   VITE_API_BASE_URL="https://api.example.com/api"
#
# Railway (service frontend, Root Directory = frontend) :
# - Définir VITE_API_BASE_URL vers l’URL publique du backend + /api (injectée au moment du build).
# - Ajouter cette URL dans CORS_ALLOWED_ORIGINS côté backend.
#
VITE_API_BASE_URL=

