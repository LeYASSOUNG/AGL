{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "src/**",
      "public/**",
      "index.html",
      "vite.config.ts",
      "package.json",
      "package-lock.json",
      "tailwind.config.*",
      "postcss.config.*",
      "tsconfig*.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
